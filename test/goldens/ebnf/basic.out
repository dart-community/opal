                ^
                source-code-grammar-ebnf-keyword-operator
                 ^
                 source-code-grammar-ebnf-whitespace
                  ^^^
                  source-code-grammar-ebnf-literal-string-quoted-double
                     ^
                     source-code-grammar-ebnf-keyword-operator
                      ^
                      source-code-grammar-ebnf-whitespace
                       ^^^^^^^^^^
                       source-code-grammar-ebnf-identifier-variable
                                 ^
                                 source-code-grammar-ebnf-keyword-operator
                                  ^
                                  source-code-grammar-ebnf-whitespace
                                   ^^^
