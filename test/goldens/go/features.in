package sample

import "fmt"

type Pair[T comparable] struct {
	Left, Right T
}

const Answer = 0x2a
var format, trueValue, integer = 1, true, 2

func (p Pair[T]) String() string {
	go fmt.Println(p.Left, p.Right)
	ch := make(chan T, 1)
	defer close(ch)
	return fmt.Sprintf("%v/%v", p.Left, p.Right)
}

func generic[T any]() {}

func ОұОІ(еҖӨ, cap int) int {
	generic[[]int]()
	generic[map[string]int]()
	generic[map[string][]byte]()
	еҸҳйҮҸ := еҖӨ
	ifПҖ := 2
	trueеҖӨ := 3
	xЩЈ := 4
	stringеҖӨ := "identifier, not a built-in type"
	return cap + еҸҳйҮҸ + ifПҖ + trueеҖӨ + xЩЈ + len(stringеҖӨ)
}
