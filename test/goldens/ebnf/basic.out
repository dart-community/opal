                              ^
                              source-code-grammar-ebnf-keyword-operator
                               ^
                               source-code-grammar-ebnf-whitespace
                                ^^^
                                source-code-grammar-ebnf-literal-string-quoted-double
                                   ^
                                   source-code-grammar-ebnf-whitespace
                                    ^
                                    source-code-grammar-ebnf-keyword-operator
                                     ^
                                     source-code-grammar-ebnf-whitespace
                                      ^^^
                                      source-code-grammar-ebnf-literal-string-quoted-double
                                         ^
                                         source-code-grammar-ebnf-whitespace
                                          ^
                                          source-code-grammar-ebnf-keyword-operator
                                           ^
                                           source-code-grammar-ebnf-whitespace
                                            ^^^
                                            source-code-grammar-ebnf-literal-string-quoted-double
                                               ^
                                               source-code-grammar-ebnf-whitespace
                                                ^
                                                source-code-grammar-ebnf-keyword-operator
                                                 ^
                                                 source-code-grammar-ebnf-whitespace
                                                  ^^^
                                                  source-code-grammar-ebnf-literal-string-quoted-double
                                                     ^
                                                     source-code-grammar-ebnf-whitespace
                                                      ^
                                                      source-code-grammar-ebnf-keyword-operator
                                                       ^
                                                       source-code-grammar-ebnf-whitespace
                                                        ^^^
                                                        source-code-grammar-ebnf-literal-string-quoted-double
                                                           ^
                                                           source-code-grammar-ebnf-whitespace
                                                            ^
                                                            source-code-grammar-ebnf-keyword-operator
                                                             ^
                                                             source-code-grammar-ebnf-whitespace
                                                              ^^^
                                                              source-code-grammar-ebnf-literal-string-quoted-double
                                                                 ^
                                                                 source-code-grammar-ebnf-whitespace
                                                                  ^
                                                                  source-code-grammar-ebnf-punctuation-separator

(* A comment that
^^
source-code-grammar-ebnf-comment-block-comment-block-begin
  ^^^^^^^^^^^^^^^
  source-code-grammar-ebnf-comment-block-comment-block-content
   spans multiple lines,
^^^^^^^^^^^^^^^^^^^^^^^^
source-code-grammar-ebnf-comment-block-comment-block-content
   with (* a nested comment *) inside. *)
^^^^^^^^
source-code-grammar-ebnf-comment-block-comment-block-content
        ^^
        source-code-grammar-ebnf-comment-block-comment-block-comment-block-begin
          ^^^^^^^^^^^^^^^^^^
          source-code-grammar-ebnf-comment-block-comment-block-comment-block-content
                            ^^
                            source-code-grammar-ebnf-comment-block-comment-block-comment-block-end
                              ^^^^^^^^^
                              source-code-grammar-ebnf-comment-block-comment-block-content
                                       ^^
                                       source-code-grammar-ebnf-comment-block-comment-block-end

empty sequence = ;
^^^^^^^^^^^^^^
source-code-grammar-ebnf-identifier-function
              ^
              source-code-grammar-ebnf-whitespace
               ^
               source-code-grammar-ebnf-keyword-operator
                ^
                source-code-grammar-ebnf-whitespace
                 ^
                 source-code-grammar-ebnf-punctuation-separator
uses empty = empty sequence ;
^^^^^^^^^^
source-code-grammar-ebnf-identifier-function
          ^
          source-code-grammar-ebnf-whitespace
           ^
           source-code-grammar-ebnf-keyword-operator
            ^
            source-code-grammar-ebnf-whitespace
             ^^^^^^^^^^^^^^
             source-code-grammar-ebnf-identifier-variable
                           ^
                           source-code-grammar-ebnf-whitespace
                            ^
                            source-code-grammar-ebnf-punctuation-separator
optional part = [ sign ] .
^^^^^^^^^^^^^
source-code-grammar-ebnf-identifier-function
             ^
             source-code-grammar-ebnf-whitespace
              ^
              source-code-grammar-ebnf-keyword-operator
               ^
               source-code-grammar-ebnf-whitespace
                ^
                source-code-grammar-ebnf-punctuation
                 ^
                 source-code-grammar-ebnf-whitespace
                  ^^^^
                  source-code-grammar-ebnf-identifier-variable
                      ^
                      source-code-grammar-ebnf-whitespace
                       ^
                       source-code-grammar-ebnf-punctuation
                        ^
                        source-code-grammar-ebnf-whitespace
                         ^
                         source-code-grammar-ebnf-punctuation-separator
also optional = (/ sign /) .
^^^^^^^^^^^^^
source-code-grammar-ebnf-identifier-function
             ^
             source-code-grammar-ebnf-whitespace
              ^
              source-code-grammar-ebnf-keyword-operator
               ^
               source-code-grammar-ebnf-whitespace
                ^^
                source-code-grammar-ebnf-punctuation
