                        ^^
                        source-code-grammar-ebnf-punctuation
                          ^
                          source-code-grammar-ebnf-whitespace
                           ^
                           source-code-grammar-ebnf-punctuation-separator
repeated part = { digit } .
^^^^^^^^^^^^^
source-code-grammar-ebnf-identifier-function
             ^
             source-code-grammar-ebnf-whitespace
              ^
              source-code-grammar-ebnf-keyword-operator
               ^
               source-code-grammar-ebnf-whitespace
