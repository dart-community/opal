(* An EBNF grammar for a simple calculator language. *)
^^
source-code-grammar-ebnf-comment-block-comment-block-begin
  ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  source-code-grammar-ebnf-comment-block-comment-block-content
                                                     ^^
                                                     source-code-grammar-ebnf-comment-block-comment-block-end
expression = term, { ( "+" | "-" ), term } ;
^^^^^^^^^^
source-code-grammar-ebnf-identifier-function
          ^
          source-code-grammar-ebnf-whitespace
           ^
           source-code-grammar-ebnf-keyword-operator
            ^
            source-code-grammar-ebnf-whitespace
             ^^^^
             source-code-grammar-ebnf-identifier-variable
                 ^
